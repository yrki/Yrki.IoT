{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Api",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/backend/Api/Api.csproj",
            "launchConfigurationId": "TargetFramework=;Api",
            "serverReadyAction": {
                "killOnServerStop": true,
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "Service",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/backend/Service/Service.csproj",
            "launchConfigurationId": "TargetFramework=;service",
            "serverReadyAction": {
                "killOnServerStop": true
             }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ],
    "compounds": [
        {
            "name": "All projects",
            "configurations": [
                "Api",
                "Service"
            ]
        }
    ]
}
