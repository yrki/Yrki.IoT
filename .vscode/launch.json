{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Api",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-api",
            "program": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/backend/Api/Api.csproj",
                "--launch-profile",
                "Api"
            ],
            "cwd": "${workspaceFolder}/src/backend/Api",
            "stopAtEntry": false,
            "console": "internalConsole",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "Service",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-service",
            "program": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/backend/Service/Service.csproj",
                "--launch-profile",
                "service"
            ],
            "cwd": "${workspaceFolder}/src/backend/Service",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ],
    "compounds": [
        {
            "name": "All projects",
            "configurations": [
                "Api",
                "Service"
            ]
        }
    ]
}
