FROM node:22-alpine AS build
WORKDIR /app

ARG VITE_API_BASE_URL=/api
ARG VITE_ENABLE_BUILDINGS=false
ARG VITE_ENABLE_FORECAST=false
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_ENABLE_BUILDINGS=$VITE_ENABLE_BUILDINGS
ENV VITE_ENABLE_FORECAST=$VITE_ENABLE_FORECAST

COPY src/frontend/package*.json ./
RUN npm ci

COPY src/frontend/ ./

# Copy web-ifc WASM files into public so Vite includes them in the build
RUN cp node_modules/web-ifc/web-ifc.wasm public/ && \
    cp node_modules/web-ifc/web-ifc-mt.wasm public/

RUN npm run build

FROM nginx:1.27-alpine AS final
COPY src/frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
