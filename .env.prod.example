# Domain — used by Caddy for automatic HTTPS via Let's Encrypt
DOMAIN=iot.example.com

# PostgreSQL
POSTGRES_USER=yrkiiot
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# RabbitMQ
RABBITMQ_USER=yrkiiot
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password

# Encryption master key for stored device keys (base64, 32 bytes)
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=CHANGE_ME_base64_key

# Azure Communication Services (email for magic link login)
EMAIL_CONNECTION_STRING=endpoint=https://...;accesskey=...
EMAIL_SENDER_ADDRESS=DoNotReply@your-domain.azurecomm.net

# MQTT gateway ingestion (set to true if you have MQTT gateways sending data)
MQTT_ENABLED=false
